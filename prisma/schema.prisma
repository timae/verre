generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        Int             @id @default(autoincrement())
  name                      String          @db.VarChar(64)
  email                     String          @unique @db.VarChar(255)
  passwordHash              String          @map("password_hash") @db.VarChar(255)
  role                      String          @default("taster") @db.VarChar(16)
  pro                       Boolean         @default(false)
  createdAt                 DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  // XP from rating wines, hosting sessions, etc. — separate from lifetime_*
  // because XP is a sum of weighted action points, not a count of actions.
  xp                        Int             @default(0)
  tokenVersion              Int             @default(0) @map("token_version")
  // Snapshot counters — monotonic, never decrement. Drive badge progression
  // and shield user achievement state from rating deletions (e.g. when a
  // host deletes a session that contained the user's ratings).
  lifetimeRatings           Int             @default(0) @map("lifetime_ratings")
  lifetimeFiveStar          Int             @default(0) @map("lifetime_five_star")
  lifetimeOneStar           Int             @default(0) @map("lifetime_one_star")
  lifetimeNotesWritten      Int             @default(0) @map("lifetime_notes_written")
  lifetimeMaxNoteLength     Int             @default(0) @map("lifetime_max_note_len")
  lifetimeSessionsJoined    Int             @default(0) @map("lifetime_sessions_joined")
  lifetimeSessionsHosted    Int             @default(0) @map("lifetime_sessions_hosted")
  lifetimePhotosAdded       Int             @default(0) @map("lifetime_photos_added")
  lifetimeConsecutiveMonths Int             @default(0) @map("lifetime_consecutive_months")
  firstRatedAt              DateTime?       @map("first_rated_at") @db.Timestamp(6)
  bookmarks                 Bookmark[]
  hofEntries                HallOfFame[]
  ratings                   Rating[]
  members                   SessionMember[]
  hostedSessions            Session[]
  earnedBadges              UserBadge[]
  followers                 Follow[]       @relation("UserFollowing")
  following                 Follow[]       @relation("UserFollowers")
  checkins                  Checkin[]
  checkinLikes              CheckinLike[]
  checkinTags               CheckinTag[]

  @@map("users")
}

model Session {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.VarChar(16)
  hostUserId  Int?      @map("host_user_id")
  hostName    String    @map("host_name") @db.VarChar(64)
  blind       Boolean   @default(false)
  createdAt   DateTime  @map("created_at") @db.Timestamptz(6)
  archivedAt  DateTime  @default(now()) @map("archived_at") @db.Timestamptz(6)
  name        String?   @db.VarChar(255)
  address     String?   @db.VarChar(255)
  dateFrom    DateTime? @map("date_from") @db.Timestamptz(6)
  dateTo      DateTime? @map("date_to") @db.Timestamptz(6)
  timezone    String?   @db.VarChar(64)
  description String?
  link        String?   @db.VarChar(512)
  host        User?     @relation(fields: [hostUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  wines       Wine[]

  @@map("sessions")
}

model Wine {
  id          String     @id @db.VarChar(20)
  // Nullable so wines can be retained when their session is deleted —
  // bookmarked wines stay reachable from the bookmark page even after the
  // hosting session is gone. Wines with sessionId=NULL are orphans.
  sessionId   Int?       @map("session_id")
  name        String     @db.VarChar(255)
  producer    String?    @db.VarChar(255)
  vintage     String?    @db.Char(4)
  grape       String?    @db.VarChar(255)
  category    String     @default("wine") @db.VarChar(32)
  style       String?    @db.VarChar(64)
  imageUrl    String?    @map("image_url")
  purchaseUrl String?    @map("purchase_url")
  revealedAt  DateTime?  @map("revealed_at") @db.Timestamptz(6)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  bookmarks   Bookmark[]
  ratings     Rating[]
  session     Session?   @relation(fields: [sessionId], references: [id], onUpdate: NoAction)

  @@map("wines")
}

model Rating {
  id        Int      @id @default(autoincrement())
  wineId    String   @map("wine_id") @db.VarChar(20)
  userId    Int?     @map("user_id")
  raterName String   @map("rater_name") @db.VarChar(64)
  score     Int      @db.SmallInt
  flavors   Json     @default("{}")
  notes     String?
  ratedAt   DateTime @map("rated_at") @db.Timestamptz(6)
  user      User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  wine      Wine     @relation(fields: [wineId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([wineId, userId])
  @@map("ratings")
}

model SessionMember {
  userId      Int      @map("user_id")
  sessionCode String   @map("session_code") @db.VarChar(16)
  joinedAt    DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)
  role        String   @default("taster") @db.VarChar(16)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  // No FK to Session — session_code links to Redis; Postgres session row may not exist yet

  @@id([userId, sessionCode])
  @@map("session_members")
}

model Bookmark {
  id      Int      @id @default(autoincrement())
  userId  Int      @map("user_id")
  wineId  String   @map("wine_id") @db.VarChar(20)
  savedAt DateTime @default(now()) @map("saved_at") @db.Timestamptz(6)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wine    Wine     @relation(fields: [wineId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, wineId])
  @@map("bookmarks")
}

model HallOfFame {
  id          Int      @id @default(autoincrement())
  wineName    String   @map("wine_name") @db.VarChar(255)
  producer    String?  @db.VarChar(255)
  vintage     String?  @db.Char(4)
  category    String   @default("wine") @db.VarChar(32)
  style       String?  @db.VarChar(64)
  score       Int      @db.SmallInt
  raterName   String   @map("rater_name") @db.VarChar(64)
  userId      Int?     @map("user_id")
  sessionCode String?  @map("session_code") @db.VarChar(16)
  ratedAt     DateTime @map("rated_at") @db.Timestamptz(6)
  user        User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([wineName, userId])
  @@map("hall_of_fame")
}

// Badge catalog. Seeded from lib/badges.ts via ensureBadgesSeedOnce().
// IDs are stable string keys ("first_pour", "rated_10", etc.), not
// autoincrement integers — easier to reference from code.
model Badge {
  id          String      @id @db.VarChar(60)
  name        String      @db.VarChar(100)
  description String      @db.VarChar(255)
  icon        String      @db.VarChar(10)
  category    String      @db.VarChar(30)
  rarity      String      @default("common") @db.VarChar(20)
  xpReward    Int         @default(50) @map("xp_reward")
  earnedBy    UserBadge[]

  @@map("badges")
}

// Awarded-badge join table. (userId, badgeId) is unique — a user can earn
// each badge at most once. `seen` flips to true when the user views their
// badges list, used to drive the "new badge" notification dot.
model UserBadge {
  id       Int      @id @default(autoincrement())
  userId   Int      @map("user_id")
  badgeId  String   @map("badge_id") @db.VarChar(60)
  earnedAt DateTime @default(now()) @map("earned_at") @db.Timestamptz(6)
  seen     Boolean  @default(false)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

// ── Social Feed ───────────────────────────────────────────────

// Explicit social graph — who follows whom.
model Follow {
  followerId  Int      @map("follower_id")
  followingId Int      @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  follower    User     @relation("UserFollowers",  fields: [followerId],  references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowing",  fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

// Standalone wine check-ins — log a bottle outside a session.
model Checkin {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  wineName  String   @map("wine_name") @db.VarChar(255)
  producer  String?  @db.VarChar(255)
  vintage   String?  @db.Char(4)
  grape     String?  @db.VarChar(255)
  type      String?  @db.VarChar(16)
  score     Int?     @db.SmallInt
  flavors   Json     @default("{}")
  notes     String?
  imageUrl  String?  @map("image_url")
  venueName String?  @map("venue_name") @db.VarChar(255)
  city      String?  @db.VarChar(100)
  country   String?  @db.Char(2)
  lat       Decimal? @db.Decimal(9, 6)
  lng       Decimal? @db.Decimal(9, 6)
  isPublic  Boolean  @default(true) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     CheckinLike[]
  tags      CheckinTag[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("checkins")
}


model CheckinTag {
  checkinId  Int     @map("checkin_id")
  userId     Int     @map("user_id")
  checkin    Checkin @relation(fields: [checkinId], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@id([checkinId, userId])
  @@index([userId])
  @@map("checkin_tags")
}

model CheckinLike {
  userId    Int      @map("user_id")
  checkinId Int      @map("checkin_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId],    references: [id], onDelete: Cascade)
  checkin   Checkin  @relation(fields: [checkinId], references: [id], onDelete: Cascade)

  @@id([userId, checkinId])
  @@map("checkin_likes")
}
