generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(64)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  role         String    @default("taster") @db.VarChar(16)
  pro          Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")
  tokenVersion Int       @default(0) @map("token_version")
  // Snapshot counters — monotonic, never decrement. Drive badge progression
  // and shield user achievement state from rating deletions (e.g. when a
  // host deletes a session that contained the user's ratings).
  lifetimeRatings           Int       @default(0) @map("lifetime_ratings")
  lifetimeFiveStar          Int       @default(0) @map("lifetime_five_star")
  lifetimeOneStar           Int       @default(0) @map("lifetime_one_star")
  lifetimeNotesWritten      Int       @default(0) @map("lifetime_notes_written")
  lifetimeMaxNoteLength     Int       @default(0) @map("lifetime_max_note_len")
  lifetimeSessionsJoined    Int       @default(0) @map("lifetime_sessions_joined")
  lifetimeSessionsHosted    Int       @default(0) @map("lifetime_sessions_hosted")
  lifetimePhotosAdded       Int       @default(0) @map("lifetime_photos_added")
  lifetimeConsecutiveMonths Int       @default(0) @map("lifetime_consecutive_months")
  firstRatedAt              DateTime? @map("first_rated_at")
  members      SessionMember[]
  ratings      Rating[]
  bookmarks    Bookmark[]
  hofEntries   HallOfFame[]

  @@map("users")
}

model Session {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.Char(4)
  hostUserId  Int?      @map("host_user_id")
  hostName    String    @map("host_name") @db.VarChar(64)
  name        String?   @db.VarChar(255)
  blind       Boolean   @default(false)
  createdAt   DateTime  @map("created_at")
  archivedAt  DateTime  @default(now()) @map("archived_at")
  address     String?   @db.VarChar(255)
  dateFrom    DateTime? @map("date_from")
  dateTo      DateTime? @map("date_to")
  timezone    String?   @db.VarChar(64)
  description String?   @db.Text
  link        String?   @db.VarChar(512)
  wines       Wine[]

  @@map("sessions")
}

model Wine {
  id          String    @id @db.VarChar(20)
  // Nullable so wines can be retained when their session is deleted —
  // bookmarked wines stay reachable from the bookmark page even after the
  // hosting session is gone. Wines with sessionId=NULL are orphans.
  sessionId   Int?      @map("session_id")
  session     Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  name        String    @db.VarChar(255)
  producer    String?
  vintage     String?   @db.Char(4)
  grape       String?
  category    String    @default("wine") @db.VarChar(32)
  style       String?   @db.VarChar(64)
  imageUrl    String?   @map("image_url")
  purchaseUrl String?   @map("purchase_url")
  revealedAt  DateTime? @map("revealed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  ratings     Rating[]
  bookmarks   Bookmark[]

  @@map("wines")
}

model Rating {
  id         Int      @id @default(autoincrement())
  wineId     String   @map("wine_id") @db.VarChar(20)
  wine       Wine     @relation(fields: [wineId], references: [id], onDelete: Cascade)
  userId     Int?     @map("user_id")
  user       User?    @relation(fields: [userId], references: [id])
  raterName  String   @map("rater_name") @db.VarChar(64)
  isHost     Boolean  @default(false) @map("is_host")
  score      Int      @db.SmallInt
  flavors    Json     @default("{}")
  notes      String?
  ratedAt    DateTime @map("rated_at")

  @@unique([wineId, userId])
  @@map("ratings")
}

model SessionMember {
  userId      Int      @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionCode String   @map("session_code") @db.Char(4)
  role        String   @default("taster") @db.VarChar(16)
  joinedAt    DateTime @default(now()) @map("joined_at")
  // No FK to Session — session_code links to Redis; Postgres session row may not exist yet
  @@id([userId, sessionCode])
  @@map("session_members")
}

model Bookmark {
  id      Int      @id @default(autoincrement())
  userId  Int      @map("user_id")
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wineId  String   @map("wine_id") @db.VarChar(20)
  wine    Wine     @relation(fields: [wineId], references: [id], onDelete: Cascade)
  savedAt DateTime @default(now()) @map("saved_at")

  @@unique([userId, wineId])
  @@map("bookmarks")
}

model HallOfFame {
  id          Int      @id @default(autoincrement())
  wineName    String   @map("wine_name") @db.VarChar(255)
  producer    String?
  vintage     String?  @db.Char(4)
  category    String   @default("wine") @db.VarChar(32)
  style       String?  @db.VarChar(64)
  score       Int      @db.SmallInt
  raterName   String   @map("rater_name") @db.VarChar(64)
  userId      Int?     @map("user_id")
  user        User?    @relation(fields: [userId], references: [id])
  sessionCode String?  @map("session_code") @db.Char(4)
  ratedAt     DateTime @map("rated_at")

  @@unique([wineName, userId])
  @@map("hall_of_fame")
}
