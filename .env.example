# Verre — environment variables
# Copy to .env and fill in real values for local development.
# Production values are set as env vars in Deploio.

# ── Required ──────────────────────────────────────────────────

# Redis: live session state (wines, ratings, identities, tokens).
# Local: docker run -d -p 6379:6379 redis:7-alpine
REDIS_URL=redis://localhost:6379

# Postgres: accounts, archived sessions, bookmarks, Hall of Fame, badges.
DATABASE_URL=postgres://verre:verre@localhost:5432/verre

# NextAuth + signed-timestamp register tokens. Any random 32+ byte string.
# Generate one: openssl rand -base64 32
# Three env names are accepted (in lookup order): AUTH_SECRET, NEXTAUTH_SECRET, JWT_SECRET.
AUTH_SECRET=change-me-in-prod

# ── S3-compatible object storage (bottle photos) ──────────────

S3_ENDPOINT=https://your-s3-endpoint.example.com
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# ── Optional ──────────────────────────────────────────────────

# NextAuth needs to know its public URL behind a reverse proxy. Local:
# NEXTAUTH_URL=http://localhost:3000
# Production sets this via Deploio.

# PORT defaults to 8080 in the Dockerfile / production. Local dev uses 3000.
# PORT=3000

# Server Actions CSRF allowlist: comma-separated extra origins (host:port, no scheme).
# localhost:8080 is always allowed. Set this to your deployed hostname in production.
# SERVER_ACTIONS_ALLOWED_ORIGINS=tasting.example.com,staging.example.com

# Public hostname used as contact info in the Nominatim (OSM) User-Agent header
# emitted by /api/places when GOOGLE_PLACES_API_KEY is unset. Falls back to
# 'self-hosted' if unset. Set to your deployed hostname in production.
# PUBLIC_HOSTNAME=tasting.example.com

# Disable Next.js anonymous telemetry. Set on Deploio for production.
# NEXT_TELEMETRY_DISABLED=1
